<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.aplikasi_ecommerce.usermaincontroller">

    <!-- BAGIAN ATAS: NAVIGASI (HEADER) -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #ffffff; -fx-border-color: #e2e2e2; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
            </padding>
            <children>
                <Button fx:id="btnKelolaProduk" onAction="#bukahalamanadmin" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Dashboard Toko" />
                <Button fx:id="btnRiwayatRating" onAction="#goToRiwayat" style="-fx-background-color: #ffc107; -fx-text-fill: black; -fx-font-weight: bold; -fx-cursor: hand;" text="⭐ Riwayat &amp; Rating" />
                <Button onAction="#goToKeranjang" style="-fx-background-color: #0d6efd; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="🛒 Keranjang" />

                <Region HBox.hgrow="ALWAYS" />

                <TextField fx:id="searchField" prefWidth="220.0" promptText="Cari produk impianmu..." style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 5 15;" />

                <!-- FITUR BARU: ComboBox untuk mengurutkan produk -->
                <ComboBox fx:id="comboSort" prefWidth="160.0" promptText="Urutkan Berdasarkan" style="-fx-background-radius: 20; -fx-border-radius: 20;" />

                <Button onAction="#handleLogout" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" text="Keluar" />
            </children>
        </HBox>
    </top>

    <!-- BAGIAN KIRI: KATEGORI -->
    <left>
        <VBox prefWidth="200.0" spacing="10.0" style="-fx-background-color: #ffffff; -fx-border-color: #e2e2e2; -fx-border-width: 0 1 0 0;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="15.0" right="15.0" top="20.0" />
            </padding>
            <children>
                <Label text="Kategori">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>
                <ListView fx:id="categoryListView" prefHeight="400.0" prefWidth="170.0" style="-fx-border-color: transparent;" VBox.vgrow="ALWAYS" />
            </children>
        </VBox>
    </left>

    <!-- BAGIAN TENGAH: KATALOG PRODUK -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #f8f9fa;" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="20.0">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <!-- Banner Sambutan -->
                        <VBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #e1f0ff; -fx-background-radius: 10;">
                            <padding>
                                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                            </padding>
                            <children>
                                <Label text="Selamat Datang di E-SHOP!" textFill="#0d6efd">
                                    <font>
                                        <Font name="System Bold" size="28.0" />
                                    </font>
                                </Label>
                                <Label text="Temukan produk terbaik dari berbagai toko dengan harga menarik." textFill="#4a4a4a">
                                    <font>
                                        <Font size="14.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <Label text="Rekomendasi Untukmu">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>

                        <!-- Grid Produk -->
                        <GridPane fx:id="productGrid" hgap="20.0" vgap="20.0">
                        </GridPane>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
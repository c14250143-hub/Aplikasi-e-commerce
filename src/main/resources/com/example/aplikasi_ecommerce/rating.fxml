<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15.0" prefWidth="350.0" prefHeight="250.0" style="-fx-background-color: #ffffff; -fx-padding: 25;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.aplikasi_ecommerce.controllerrating">
    <children>
        <Label text="Beri Rating Produk" textFill="#0d6efd">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <Label fx:id="lblNamaProduk" text="Berikan Ulasan Anda untuk: [Nama Produk]" textAlignment="CENTER" wrapText="true" style="-fx-text-fill: #495057; -fx-font-size: 13px;" />

        <HBox alignment="CENTER" spacing="10.0">
            <children>
                <Label text="Pilih Bintang:">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Label>
                <ComboBox fx:id="comboBintang" prefWidth="80.0" style="-fx-cursor: hand;" />
                <Label text="⭐" style="-fx-font-size: 16px; -fx-text-fill: #ffc107;" />
            </children>
        </HBox>

        <HBox alignment="CENTER" spacing="15.0">
            <children>
                <Button onAction="#handleBatal" text="Batal" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-cursor: hand;" />
                <Button onAction="#handleSimpanRating" text="Kirim Ulasan" style="-fx-background-color: #ffc107; -fx-text-fill: #212529; -fx-font-weight: bold; -fx-cursor: hand;" />
            </children>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>
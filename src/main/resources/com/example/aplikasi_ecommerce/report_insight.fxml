<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox spacing="15.0" prefWidth="800.0" prefHeight="600.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.aplikasi_ecommerce.reportcontroller">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Dashboard Laporan Analisis - Business Insight" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    <Label text="Menampilkan statistik dan performa khusus untuk toko Anda." style="-fx-text-fill: #6c757d;"/>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>
            <!-- TAB 1: ANALISIS KUALITAS PRODUK -->
            <Tab text="Analisis Kualitas Produk">
                <VBox spacing="10.0">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <TableView fx:id="tableProduk" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colProdToko" text="ID Toko" prefWidth="100"/>
                            <TableColumn fx:id="colProdId" text="ID Produk" prefWidth="120"/>
                            <TableColumn fx:id="colProdNama" text="Nama Produk" prefWidth="250"/>
                            <TableColumn fx:id="colProdTotalReview" text="Total Ulasan" prefWidth="150"/>
                            <TableColumn fx:id="colProdRating" text="Rata-Rata Rating ⭐" prefWidth="150"/>
                        </columns>
                    </TableView>
                    <Text text="Insight: Membantu Anda mengidentifikasi produk unggulan (hero product) untuk strategi promosi." style="-fx-font-style: italic; -fx-fill: gray;"/>
                </VBox>
            </Tab>

            <!-- TAB 2: ANALISIS PERFORMA REPUTASI TOKO -->
            <Tab text="Analisis Performa Reputasi Toko">
                <VBox spacing="10.0">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <TableView fx:id="tableToko" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colTokoId" text="ID Toko" prefWidth="120"/>
                            <TableColumn fx:id="colTokoRating" text="Rating Agregat ⭐" prefWidth="150"/>
                            <TableColumn fx:id="colTokoFeedback" text="Total Feedback Masuk" prefWidth="180"/>
                            <TableColumn fx:id="colTokoStatus" text="Status Klasifikasi Reputasi" prefWidth="250"/>
                        </columns>
                    </TableView>
                    <Text text="Insight: Jaga reputasi toko Anda tetap pada status 'Sangat Puas' agar mendapatkan lencana Star Seller." style="-fx-font-style: italic; -fx-fill: gray;"/>
                </VBox>
            </Tab>

            <!-- TAB 3: FITUR LAPORAN EKSEKUTIF LANJUTAN -->
            <Tab text="Laporan Eksekutif Lanjutan">
                <VBox spacing="20.0" alignment="CENTER" style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 8;">
                    <padding>
                        <Insets top="40" right="40" bottom="40" left="40"/>
                    </padding>
                    <Label text="Ekspor Laporan Data Analisis Tingkat Lanjut" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label text="Pilih laporan di bawah ini. Hasil laporan akan dicetak langsung ke dalam layar Konsol / Terminal IDE." textFill="#6c757d"/>

                    <Button onAction="#handleCetakTransaksi" text="🖨️ Cetak Laporan Riwayat Transaksi (Tahun 2026)" prefWidth="380.0" prefHeight="45.0" style="-fx-background-color: #0d6efd; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;"/>
                    <Button onAction="#handleCetakPendapatan" text="🖨️ Cetak Peringkat Total Pendapatan Toko" prefWidth="380.0" prefHeight="45.0" style="-fx-background-color: #198754; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;"/>
                    <Button onAction="#handleCetakKategori" text="🖨️ Cetak Tren Kategori Produk Terlaris" prefWidth="380.0" prefHeight="45.0" style="-fx-background-color: #fd7e14; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;"/>
                </VBox>
            </Tab>
        </tabs>
    </TabPane>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="450.0" spacing="15.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.aplikasi_ecommerce.RegisterController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>
    <children>
        <Label text="Buat Akun Baru" textFill="#0d6efd">
            <font>
                <Font name="System Bold" size="26.0" />
            </font>
        </Label>
        <Label text="Lengkapi data diri Anda di bawah ini" textFill="#6c757d">
            <font>
                <Font size="14.0" />
            </font>
            <VBox.margin>
                <Insets bottom="15.0" />
            </VBox.margin>
        </Label>

        <VBox spacing="5.0">
            <children>
                <Label text="Nama Lengkap">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Label>
                <TextField fx:id="namaField" prefHeight="35.0" promptText="Masukkan nama lengkap" style="-fx-border-color: #ced4da; -fx-background-radius: 5; -fx-border-radius: 5;" />
            </children>
        </VBox>

        <VBox spacing="5.0">
            <children>
                <Label text="Email">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Label>
                <TextField fx:id="emailField" prefHeight="35.0" promptText="contoh@email.com" style="-fx-border-color: #ced4da; -fx-background-radius: 5; -fx-border-radius: 5;" />
            </children>
        </VBox>

        <VBox spacing="5.0">
            <children>
                <Label text="Nomor Telepon">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Label>
                <TextField fx:id="teleponField" prefHeight="35.0" promptText="0812xxxxxx" style="-fx-border-color: #ced4da; -fx-background-radius: 5; -fx-border-radius: 5;" />
            </children>
        </VBox>

        <VBox spacing="5.0">
            <children>
                <Label text="Alamat Lengkap">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Label>
                <TextField fx:id="alamatField" prefHeight="35.0" promptText="Masukkan alamat pengiriman" style="-fx-border-color: #ced4da; -fx-background-radius: 5; -fx-border-radius: 5;" />
            </children>
        </VBox>

        <VBox spacing="5.0">
            <children>
                <Label text="Password">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Label>
                <PasswordField fx:id="passwordField" prefHeight="35.0" promptText="Buat password yang kuat" style="-fx-border-color: #ced4da; -fx-background-radius: 5; -fx-border-radius: 5;" />
            </children>
        </VBox>

        <Button fx:id="registerButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleRegister" prefHeight="45.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" text="DAFTAR SEKARANG">
            <VBox.margin>
                <Insets top="15.0" />
            </VBox.margin>
            <font>
                <Font size="14.0" />
            </font>
        </Button>

        <Label onMouseClicked="#goToLogin" style="-fx-text-fill: #0d6efd; -fx-cursor: hand;" text="Sudah punya akun? Masuk di sini" underline="true">
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </Label>
    </children>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<!-- Memastikan xmlns:fx diatur ke URL JavaFX yang benar untuk mencegah error -->
<VBox prefHeight="550.0" prefWidth="700.0" spacing="15.0" style="-fx-padding: 25; -fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.aplikasi_ecommerce.orderhistorycontroller">
    <children>

        <VBox spacing="5.0">
            <children>
                <Label text="Riwayat Pesanan &amp; Ulasan" textFill="#0d6efd">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <Label text="Pilih pesanan Anda di tabel untuk memproses pembayaran atau memberikan rating." textFill="#6c757d">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
            </children>
        </VBox>

        <TableView fx:id="tabelRiwayat" prefHeight="350.0" prefWidth="650.0" VBox.vgrow="ALWAYS" style="-fx-border-color: #dee2e6; -fx-border-radius: 5; -fx-background-radius: 5;">
            <columns>
                <TableColumn fx:id="colIdOrder" prefWidth="100.0" text="ID Pesanan" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colTanggal" prefWidth="180.0" text="Tanggal Transaksi" />
                <TableColumn fx:id="colTotal" prefWidth="160.0" text="Total Belanja (Rp)" />
                <TableColumn fx:id="colStatus" prefWidth="200.0" text="Status Pesanan" style="-fx-font-weight: bold;" />
            </columns>
        </TableView>

        <!-- Bagian Tombol Aksi (Bawah) -->
        <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-padding: 10 0 0 0;">
            <children>
                <!-- Tombol Kembali diletakkan di sisi paling kiri menggunakan Region -->
                <Button fx:id="btnKembali" onAction="#handleKembali" prefHeight="40.0" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold; -fx-background-radius: 5;" text="⬅ Kembali ke Katalog" />

                <Region HBox.hgrow="ALWAYS" />

<!--                <Button onAction="#handleBayarSekarang" prefHeight="40.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="💳 Bayar Sekarang" />-->
                <Button onAction="#handleBeriRating" prefHeight="40.0" style="-fx-background-color: #ffc107; -fx-text-fill: #212529; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="⭐ Beri Ulasan / Rating" />
            </children>
        </HBox>

    </children>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="550.0" prefWidth="750.0" spacing="15.0" style="-fx-padding: 20; -fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.aplikasi_ecommerce.ordercontroller">
    <children>
        <Label text="Manajemen Pesanan Pelanggan" textFill="#0d6efd">
            <font>
                <Font name="System Bold" size="22.0" />
            </font>
        </Label>
        <Label text="Pilih pesanan di tabel, lalu perbarui statusnya di bawah." textFill="#6c757d" />

        <!-- TABEL PESANAN -->
        <TableView fx:id="tabelPesanan" VBox.vgrow="ALWAYS" prefHeight="350.0">
            <columns>
                <TableColumn fx:id="colIdOrder" prefWidth="90.0" text="ID Order" />
                <TableColumn fx:id="colTanggal" prefWidth="150.0" text="Tanggal" />
                <TableColumn fx:id="colTotal" prefWidth="130.0" text="Total (Rp)" />
                <TableColumn fx:id="colStatus" prefWidth="200.0" text="Status Saat Ini" />
            </columns>
        </TableView>

        <!-- AREA UPDATE STATUS -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 15; -fx-border-color: #dee2e6; -fx-border-radius: 5;">
            <children>
                <Label text="Ubah Status Menjadi:">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Label>

                <ComboBox fx:id="comboStatus" prefWidth="200.0" promptText="Pilih Status Baru" />

                <Button onAction="#handleUpdateStatus" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Simpan Perubahan" />

                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleRefresh" style="-fx-background-color: #17a2b8; -fx-text-fill: white; -fx-cursor: hand;" text="🔄 Refresh Tabel" />
            </children>
        </HBox>
    </children>
</VBox>

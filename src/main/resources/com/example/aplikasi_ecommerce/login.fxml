<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="400.0" spacing="20.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.aplikasi_ecommerce.LoginController">
   <padding>
      <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
   </padding>
   <children>
      <Label text="Selamat Datang" textFill="#0d6efd">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Label>
      <Label text="Silakan masuk ke akun E-SHOP Anda" textFill="#6c757d">
         <font>
            <Font size="14.0" />
         </font>
         <VBox.margin>
            <Insets bottom="20.0" />
         </VBox.margin>
      </Label>

      <VBox spacing="5.0">
         <children>
            <Label text="Email">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Label>
            <TextField fx:id="emailField" prefHeight="40.0" promptText="Masukkan email Anda" style="-fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #ced4da;" />
         </children>
      </VBox>

      <VBox spacing="5.0">
         <children>
            <Label text="Password">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Label>
            <PasswordField fx:id="passwordField" prefHeight="40.0" promptText="Masukkan password" style="-fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #ced4da;" />
         </children>
      </VBox>

      <Button fx:id="loginButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogin" prefHeight="45.0" style="-fx-background-color: #0d6efd; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" text="MASUK">
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
         <font>
            <Font size="14.0" />
         </font>
      </Button>

      <Label onMouseClicked="#goToRegister" style="-fx-text-fill: #0d6efd; -fx-cursor: hand;" text="Belum punya akun? Daftar di sini" underline="true">
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </Label>
   </children>
</VBox>
